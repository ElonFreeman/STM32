{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAPLink Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/f103rct6.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/stm32f1x.cfg"
            ],
            "gdbPath": "/usr/local/gcc-arm-none-eabi-10.3-2021.10/bin/arm-none-eabi-gdb",
            "svdFile": "${workspaceFolder}/.vscode/STM32F103xx.svd"
        }
    ]
}